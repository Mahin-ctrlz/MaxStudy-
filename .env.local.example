# Copy this file to .env.local for local development.
# On Vercel: Project Settings -> Environment Variables -> add the same two keys.

# Find both in Supabase: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# IMPORTANT: Never add SUPABASE_SERVICE_ROLE_KEY to this file or to Vercel's
# client-exposed env vars. This app doesn't need it — Row Level Security
# (set up in supabase/schema.sql) handles per-user data isolation instead.
# The service role key bypasses RLS entirely; if it ever ends up in a
# NEXT_PUBLIC_* variable or committed to git, anyone can read/write every
# user's data. There's no code path in this app that should use it.
